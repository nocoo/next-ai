{
  "name": "@nocoo/next-ai",
  "version": "0.2.1",
  "description": "Multi-provider AI integration for Next.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./server-next": {
      "types": "./dist/server-next.d.ts",
      "import": "./dist/server-next.js",
      "require": "./dist/server-next.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check . --write",
    "typecheck": "tsc --noEmit",
    "gate:security": "bun run scripts/gate-security.ts",
    "prepublishOnly": "bun run build",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^3.4.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "server-only": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/openai": "^3.0.36",
    "ai": "^6.0.104"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.2.5",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.0.0",
    "react": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  },
  "keywords": ["ai", "llm", "anthropic", "openai", "next.js", "react"],
  "author": "nocoo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nocoo/next-ai.git"
  },
  "bugs": {
    "url": "https://github.com/nocoo/next-ai/issues"
  },
  "homepage": "https://github.com/nocoo/next-ai#readme",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --error-on-warnings --no-errors-on-unmatched"
    ]
  }
}
